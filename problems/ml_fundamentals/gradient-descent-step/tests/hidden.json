{
  "tests": [
    {
      "name": "zero_gradient",
      "input": {
        "weights": [1.0, 2.0],
        "gradients": [0.0, 0.0],
        "learning_rate": 0.25
      },
      "expected": [1.0, 2.0]
    },
    {
      "name": "larger_step",
      "input": {
        "weights": [3.0, -2.0, 0.75],
        "gradients": [1.2, -0.4, 0.5],
        "learning_rate": 0.5
      },
      "expected": [2.4, -1.8, 0.5]
    }
  ]
}
